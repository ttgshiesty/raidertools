# Local-only environment for `cd infra && npm run local:api`
#
# This file is read automatically by `infra/local/server.ts`.
# Create `infra/.env` for your baseline local values and `infra/.env.local`
# for machine-specific overrides or secrets.

# Local API server
LOCAL_API_PORT=4000
AWS_ENDPOINT_URL_DYNAMODB=http://localhost:8000
USER_TABLE_NAME=raider-tools-users
ALLOWED_ORIGINS=http://localhost:5173
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
LOCAL_TOKEN_ENCRYPTION_KEY=dev-only-dummy-local-token-encryption-key

# ArcTracker relay
# Secret: real ArcTracker app key for local relay testing.
ARC_APP_KEY=arc_k1_dummy_local_app_key
ARC_APP_KEY_SECRET_ARN=arn:aws:secretsmanager:eu-central-1:000000000000:secret:arctracker/appKey-dummy

# AWS CDK
CDK_DEFAULT_ACCOUNT=000000000000

# Discord auth / Cognito auth Lambdas
DISCORD_SECRET_ARN=arn:aws:secretsmanager:eu-central-1:000000000000:secret:raider-tools/discord/oauth-dummy
DISCORD_REDIRECT_URI=http://localhost:4000/auth/discord/callback
USER_POOL_ID=eu-central-1_dummy
USER_POOL_CLIENT_ID=dummy_user_pool_client_id
SPA_ORIGIN=http://localhost:5173

# Schedule Lambdas
SCHEDULE_BUCKET_NAME=raider-tools-schedule-local
SCHEDULE_KEY=map-events.json
SCHEDULE_STAGING_KEY=staging/map-events.json
SCHEDULE_HEALTH_KEY=health.json
MAP_CONDITIONS_URL=https://arcraiders.com/map-conditions
EVENT_TYPES_URL=https://raider-tools.app/data/schedule/event-types.json
MERGE_HISTORY_WINDOW_SECONDS=2592000

# Production Lambda-only values. Local dev normally leaves these unset.
KMS_KEY_ID=dummy-kms-key-id
RAIDER_TOOLS_LOCAL_DEV=true
# Optional: when unset, local dev bypasses Cognito group gates. Set this to a
# comma-separated list to test exact local group membership. Use an empty value
# to test a signed-in user with no Cognito groups.
# LOCAL_COGNITO_GROUPS=embark-auth
# LOCAL_COGNITO_GROUPS=

# Embark linked-account local flow
# Required if you want the local API server to perform the real Embark OAuth
# token exchange and fetch `/v1/shared/profile`.
# Refresh-token handling is intentionally unavailable until Embark fixes its
# auth server; re-authenticate after token expiry.
# EMBARK_OAUTH_CLIENT_SECRET=...
# EMBARK_MANIFEST_ID=1668862126276720848
# EMBARK_USER_AGENT=PioneerGame/pioneer_1.13.x-CL-1067127 (http-legacy) Windows/10.0.26100.1.768.64bit

# Optional local Basic Auth credentials for GET|PUT /admin/embark/config
# EMBARK_ADMIN_USERNAME=admin
# EMBARK_ADMIN_PASSWORD=change-me

# Loopback redirect used by the browser extension
# Without the extension, use the manual callback URL rewrite flow documented by
# the site owner.
# EMBARK_LOOPBACK_REDIRECT_URI=http://127.0.0.1:49176
