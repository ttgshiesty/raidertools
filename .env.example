# Environment variables for raider-tools
# Copy this file to .env and configure as needed

# Dynamic schedule endpoint (map-events only)
# In production set this to the public API schedule URL.
# Local development can leave this unset to use /data/schedule/map-events.json.
# VITE_SCHEDULE_DATA_URL=https://api.raider-tools.app/schedule/map-events.json

# ---------------------------------------------------------------------------
# Authentication (Cognito + Discord bridge)
# ---------------------------------------------------------------------------
# These come from CDK outputs of RaiderToolsStack after `cdk deploy`:
#   - VITE_COGNITO_USER_POOL_ID  -> output "UserPoolId"
#   - VITE_COGNITO_CLIENT_ID     -> output "UserPoolClientId"
# When BOTH are unset, the SPA stays in anonymous mode (localStorage only)
# and the sign-in / sign-up pages render a friendly notice.
# VITE_COGNITO_USER_POOL_ID=eu-central-1_XXXXXXXXX
# VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Base URL for the raider-tools API. Defaults to the production endpoint
# below when unset.
# VITE_API_BASE_URL=https://api.raider-tools.app

# ---------------------------------------------------------------------------
# Local development (see docs/Local-Development.md)
# ---------------------------------------------------------------------------
# VITE_DEV_AUTH=true switches the SPA into offline dev mode:
#   - Cognito is fully bypassed; SignIn renders a "Sign in as dev user" panel.
#   - getIdToken() returns an unsigned `dev.<sub>[.<email>]` bearer token.
# Combine with VITE_API_BASE_URL=http://localhost:4000 to target the local
# Lambda-handler-backed server in `infra/local/server.ts`.
# DO NOT enable this in production Amplify builds.
# VITE_DEV_AUTH=true
# VITE_LOCAL_API_PORT=4000
