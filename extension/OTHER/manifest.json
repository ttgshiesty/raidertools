{
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "presence-raider-tools.js" ],
   "matches": [ "https://shiesty.me/*" ],
      "run_at": "document_start"
   } ],
   "declarative_net_request": {
      "rule_resources": [ {
         "enabled": true,
         "id": "ruleset_1",
         "path": "rules.json"
      } ]
   },
   "description": "Enables Embark authentication for  arcraiders shiesty-edition by routing local OAuth callbacks to the site.",
   "externally_connectable": {
      "matches": [ "https://shiesty.me/*" ]
   },
   "host_permissions": [ "http://127.0.0.1:49174/*", "https://shiesty.me/*" ],
   "icons": {
      "128": "icons/icon-128.png",
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Shiesty Raiders Embark Auth Bridge",
   "permissions": [ "declarativeNetRequest" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.0"
}
