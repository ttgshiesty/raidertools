datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  blueprintOwnerships UserBlueprintOwnership[]
  skillTreeSave       UserSkillTreeSave?
  mapProgressSave     UserMapProgressSave?
  listings            MarketplaceListing[]
  buyerOrders         MarketplaceOrder[]     @relation("BuyerOrders")
  sellerOrders        MarketplaceOrder[]     @relation("SellerOrders")
  sharedBuilds        SharedSkillTreeBuild[]
  profileSync         UserProfileSync?
  conversationsAsA    Conversation[]         @relation("ConversationsAsA")
  conversationsAsB    Conversation[]         @relation("ConversationsAsB")
  sentMessages        Message[]              @relation("SentMessages")
}

/// Versioned JSON: per-map POI visit flags (quests / containers / loot areas).
model UserMapProgressSave {
  userId    String   @id
  payload   Json
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Versioned JSON skill tree build (point allocations per skill node id).
model UserSkillTreeSave {
  userId    String   @id
  payload   Json
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Per-user blueprint tracker state (`owned` | `tracking`). Omitted rows = not owned / default.
model UserBlueprintOwnership {
  userId      String
  blueprintId String
  state       String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, blueprintId])
  @@index([userId])
}

/// Tracks the most recent profile import for a user (manual JSON upload or future OAuth).
/// One row per user — upserted on every successful sync attempt.
model UserProfileSync {
  userId            String   @id
  /// "manual" | "embark_oauth" (future)
  source            String
  /// "success" | "partial" | "failed"
  status            String
  importedAt        DateTime @updatedAt
  blueprintsCount   Int      @default(0)
  skillTreeImported Boolean  @default(false)
  errorMessage      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Publicly-shared skill tree build — visible to everyone, deletable only by the owner.
model SharedSkillTreeBuild {
  id        String   @id @default(cuid())
  userId    String
  userName  String?
  buildName String
  buildCode String
  totalPts  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

/// SHIESTY-RAIDERS-native marketplace listing backed by  item reference.
/// RaiderForge-native marketplace listing backed by the universal game asset identifier.
model MarketplaceListing {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  // The universal game identifier used across your entire system
  gameAssetId String   // You can name this publicUucid if preferred
  
  // Granular type flags so your code knows what kind of asset it is
  itemId      String?
  weaponId    String?
  enemyId     String?
  targetId    String?
  mapId       String?

  itemName    String
  itemIconUrl String?
  price       Float
  currency    String   @default("USD")
  quantity    Int      @default(1)
  status      String   @default("active") // active | sold | cancelled
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      MarketplaceOrder[]

  @@index([sellerId])
  @@index([status])
  @@index([gameAssetId]) // Lightning-fast lookups for active shop items
}

/// Full order record: price snapshot, status lifecycle, audit trail.
model MarketplaceOrder {
  id          String             @id @default(cuid())
  listingId   String
  listing     MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Restrict)
  buyerId     String
  buyer       User               @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  sellerId    String
  seller      User               @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Restrict)
  
  // Historical snapshot tracking the asset traded
  gameAssetId String
  
  itemId      String?
  weaponId    String?
  enemyId     String?
  targetId    String?
  mapId       String?

  itemName    String
  itemIconUrl String?
  unitPrice   Float
  currency    String
  quantity    Int
  totalAmount Float              // unitPrice * quantity, computed server-side
  status      String             @default("pending") // pending | awaiting_payment | paid ...
  buyerNote   String?
  sellerNote  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  events      MarketplaceOrderEvent[]
  conversation Conversation?

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([status])
  @@index([gameAssetId])
}

/// A conversation between exactly two users. orderId links it to a marketplace order thread.
/// participantAId is always the lexicographically smaller userId — enforces deduplication.
model Conversation {
  id             String    @id @default(cuid())
  participantAId String
  participantBId String
  participantA   User      @relation("ConversationsAsA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB   User      @relation("ConversationsAsB", fields: [participantBId], references: [id], onDelete: Cascade)
  orderId        String?   @unique
  order          MarketplaceOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  messages       Message[]
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  @@unique([participantAId, participantBId])
  @@index([participantAId, updatedAt(sort: Desc)])
  @@index([participantBId, updatedAt(sort: Desc)])
}

/// A single message within a conversation. readAt=null means unread by the other participant.
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt(sort: Asc)])
  @@index([conversationId, readAt])
}

/// Append-only audit log for every order status transition.
model MarketplaceOrderEvent {
  id         String   @id @default(cuid())
  orderId    String
  order      MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  /// User who triggered the transition; null = system.
  actorId    String?
  fromStatus String?
  toStatus   String
  note       String?

  createdAt  DateTime @default(now())

  @@index([orderId])
}
