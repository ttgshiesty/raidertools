+
+type JsonObject = Record<string, unknown>;
+
+function isRecord(value: unknown): value is JsonObject {
+  return value !== null && typeof value === 'object' && !Array.isArray(value);
+}
+
+function body(value: unknown): JsonObject {
+  const root = isRecord(value) ? value : {};
+  return isRecord(root.data) ? root.data : root;
+}
+
+function finiteNumber(value: unknown): number | null {
+  if (typeof value === 'number') return Number.isFinite(value) ? value : null;
+  if (typeof value === 'string' && value.trim() !== '') {
+    const parsed = Number(value);
+    return Number.isFinite(parsed) ? parsed : null;
+  }
+  return null;
+}
+
+function numberOrZero(value: unknown): number {
+  return finiteNumber(value) ?? 0;
+}
+
+function firstNumber(source: JsonObject, keys: readonly string[]): number {
+  for (const key of keys) {
+    const parsed = finiteNumber(source[key]);
+    if (parsed !== null) return parsed;
+  }
+  return 0;
+}
+
+function firstString(source: JsonObject, keys: readonly string[], fallback: string): string {
+  for (const key of keys) {
+    const value = source[key];
+    if (typeof value === 'string' && value.trim()) return value.trim();
+    if (typeof value === 'number' && Number.isFinite(value)) return String(value);
+  }
+  return fallback;
+}
+
+function arrayOfRecords(value: unknown): JsonObject[] {
+  return Array.isArray(value) ? value.filter(isRecord) : [];
+}
+
+function cleanStatName(value: unknown, fallback: string): string {
+  const text = typeof value === 'string' && value.trim() ? value.trim() : fallback;
+  return text
+    .replace(/_kills$/i, '')
+    .replace(/^kills_/i, '')
+    .replace(/_/g, ' ')
+    .replace(/\b\w/g, (letter) => letter.toUpperCase())
+    .trim();
+}
+
+function normalizeEnemyStats(value: unknown): MetaForgeEnemyStats[] {
+  if (Array.isArray(value)) {
+    return value.filter(isRecord).map((enemy, index) => ({
+      user_id: typeof enemy.user_id === 'string' ? enemy.user_id : undefined,
+      enemy_name: firstString(enemy, ['enemy_name', 'enemyName', 'name', 'targetName', 'target_name'], `Unknown Enemy ${index + 1}`),
+      kills: firstNumber(enemy, ['kills', 'count', 'totalKills', 'total_kills']),
+      damage: firstNumber(enemy, ['damage', 'totalDamage', 'total_damage', 'damageDealt', 'damage_dealt']),
+      ...(typeof enemy.last_updated === 'string' ? { last_updated: enemy.last_updated } : {}),
+    }));
+  }
+
+  const source = isRecord(value) ? value : {};
+  return Object.entries(source)
+    .filter(([, amount]) => finiteNumber(amount) !== null && numberOrZero(amount) > 0)
+    .map(([key, amount]) => ({
+      enemy_name: cleanStatName(key, key),
+      kills: numberOrZero(amount),
+      damage: 0,
+    }));
+}
+
+function normalizeWeaponStats(value: unknown): MetaForgeWeaponStats[] {
+  if (Array.isArray(value)) {
+    return value.filter(isRecord).map((weapon, index) => ({
+      user_id: typeof weapon.user_id === 'string' ? weapon.user_id : undefined,
+      weapon_name: firstString(weapon, ['weapon_name', 'weaponName', 'name', 'title'], `Unknown Weapon ${index + 1}`),
+      kills: firstNumber(weapon, ['kills', 'count', 'totalKills', 'total_kills']),
+      count: firstNumber(weapon, ['count', 'kills', 'totalKills', 'total_kills']),
+      damage: firstNumber(weapon, ['damage', 'totalDamage', 'total_damage', 'damageDealt', 'damage_dealt']),
+      ...(typeof weapon.last_updated === 'string' ? { last_updated: weapon.last_updated } : {}),
+    }));
+  }
+
+  const source = isRecord(value) ? value : {};
+  const rows = new Map<string, MetaForgeWeaponStats>();
+
+  function add(name: string, kills: number, damage: number): void {
+    const existing = rows.get(name) ?? { weapon_name: name, kills: 0, count: 0, damage: 0 };
+    existing.kills = numberOrZero(existing.kills) + kills;
+    existing.count = numberOrZero(existing.count) + kills;
+    existing.damage += damage;
+    rows.set(name, existing);
+  }
+
+  function crawl(obj: JsonObject): void {
+    for (const [key, raw] of Object.entries(obj)) {
+      if (finiteNumber(raw) !== null && /kills/i.test(key)) {
+        add(cleanStatName(key, key), numberOrZero(raw), 0);
+      } else if (isRecord(raw)) {
+        const kills = firstNumber(raw, ['kills', 'count', 'totalKills', 'total_kills']);
+        const damage = firstNumber(raw, ['damage', 'totalDamage', 'total_damage', 'damageDealt', 'damage_dealt']);
+        if (kills || damage) add(cleanStatName(key, key), kills, damage);
+        else crawl(raw);
+      }
+    }
+  }
+
+  crawl(source);
+  return Array.from(rows.values());
 }
 
