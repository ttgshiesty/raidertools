{
  "name": "shiesty",
  "private": true,
  "version": "1.0.0",
  "description": "Unified shiesty raiders tools collection",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate": "npm run generate:items && npm run generate:quests && npm run generate:hideout && npm run generate:projects-quartermaster && npm run generate:embark-inventory-mapping && npm run generate:schedule",
    "generate:quests": "./scripts/generate-quest-data.sh",
    "generate:items": "npx tsx ./scripts/generate-items.ts",
    "generate:hideout": "npx tsx ./scripts/generate-hideout.ts",
    "generate:embark-inventory-mapping": "node ./scripts/generate-embark-inventory-mapping.js",
    "generate:maps-localizations": "node ./scripts/generate-map-localizations.js",
    "generate:map-events-localizations": "node ./scripts/generate-map-event-localizations.js",
    "generate:schedule": "npm run generate:maps-localizations && npm run generate:map-events-localizations && node ./scripts/generate-schedule-data-from-map-conditions.js",
    "generate:projects-quartermaster": "npx tsx ./scripts/generate-quartermaster-projects.ts"
  },
  "dependencies": {
    "amazon-cognito-identity-js": "^6.3.16",
    "dagre": "^0.8.5",
    "elkjs": "^0.11.1",
    "idb": "^8.0.3",
    "immer": "^11.1.8",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.5.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/dagre": "^0.7.53",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.1.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "prettier-plugin-sort-json": "^4.2.0",
    "safe-stable-stringify": "^2.5.0",
    "sass": "^1.97.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.27.2": true,
    "@parcel/watcher@2.5.6": true,
    "fsevents@2.3.3": true
  }
}
